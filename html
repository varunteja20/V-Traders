<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>V Traders</title>

<style>
body {
    margin: 0;
    font-family: "Times New Roman", serif;
    color: white;
    background: linear-gradient(to bottom, #020311, #050a1f);
    overflow-x: hidden;
}

/* ⭐ Stars */
.star {
    position: fixed;
    width: 2px;
    height: 2px;
    background: white;
    border-radius: 50%;
    animation: twinkle 2s infinite alternate;
}

@keyframes twinkle {
    from { opacity: 0.2; }
    to { opacity: 1; }
}

/* Header */
header {
    text-align: center;
    padding: 20px;
    background: black;
}

/* Layout */
.container {
    display: grid;
    grid-template-columns: 3fr 1fr;
}

/* Products */
.products {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    padding: 20px;
    gap: 20px;
}

.card {
    background: rgba(255,255,255,0.1);
    padding: 15px;
    border-radius: 10px;
}

.card img {
    width: 100%;
    border-radius: 10px;
}

button {
    background: white;
    color: black;
    padding: 10px;
    border: none;
    width: 100%;
    margin-top: 10px;
    cursor: pointer;
}

/* Cart */
.cart {
    background: rgba(0,0,0,0.7);
    padding: 15px;
}

.total {
    font-weight: bold;
    margin-top: 10px;
}

select {
    width: 100%;
    padding: 10px;
    margin-top: 10px;
}
</style>
</head>

<body>

<script>
for (let i = 0; i < 80; i++) {
    let star = document.createElement("div");
    star.className = "star";
    star.style.top = Math.random() * 100 + "%";
    star.style.left = Math.random() * 100 + "%";
    document.body.appendChild(star);
}
</script>

<header>
    <h1>V Traders</h1>
</header>

<div class="container">

    <!-- PRODUCTS -->
    <div class="products">

        <div class="card">
            <img src="https://images.unsplash.com/photo-1512436991641-6745cdb1723f">
            <h3>Jacket</h3>
            <p>₹1499</p>
            <button onclick="addToCart('Jacket',1499)">Add to Cart</button>
        </div>

        <div class="card">
            <img src="https://images.unsplash.com/photo-1520975916090-3105956dac38">
            <h3>Sneakers</h3>
            <p>₹1999</p>
            <button onclick="addToCart('Sneakers',1999)">Add to Cart</button>
        </div>

    </div>

    <!-- CART -->
    <div class="cart">
        <h2>🛒 Cart</h2>
        <div id="cartItems"></div>
        <div class="total" id="total">Total: ₹0</div>

        <h3>Payment</h3>
        <select id="payment">
            <option>UPI</option>
            <option>Credit Card</option>
            <option>Debit Card</option>
            <option>Cash on Delivery</option>
        </select>

        <button onclick="checkout()">Checkout</button>
    </div>

</div>

<script>
let total = 0;

function addToCart(name, price) {
    let cart = document.getElementById("cartItems");
    cart.innerHTML += "<p>" + name + " - ₹" + price + "</p>";
    total += price;
    document.getElementById("total").innerText = "Total: ₹" + total;
}

function checkout() {
    let method = document.getElementById("payment").value;
    alert("Order placed using " + method + " 🎉");
}
</script>

</body>
</html>
